# Copy to .env.local and fill in. Without these, the app runs in LOCAL DEMO
# mode (mock data in localStorage). With them set, it uses the real Supabase
# backend (auth + database + realtime).

# Supabase (Project Settings → API)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Force a backend explicitly. "auto" (default) uses Supabase when the URL +
# key above are present, otherwise local demo mode.
# VITE_BACKEND=auto   # auto | local | supabase

# Error tracking (optional). Leave blank to disable.
VITE_SENTRY_DSN=

# Web Push (optional). Public VAPID key for the browser; the matching private
# key lives only on the server / Supabase Edge Function.
VITE_VAPID_PUBLIC_KEY=
